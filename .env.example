# Copie para .env e preencha. NUNCA versione o .env real.
# Stack 100% local: Ollama + N8N + Open WebUI.

# --- LLM (Ollama local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2

# --- N8N ---
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ai-sdr

# --- Open WebUI ---
OPENWEBUI_BASE_URL=http://localhost:3000

# --- Vector DB (RAG - base de cases), a definir ---
VECTOR_DB=
VECTOR_DB_PATH=./vector_store

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO

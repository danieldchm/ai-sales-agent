# Copie para .env e preencha. NUNCA versione o .env real.
# Stack 100% local: Ollama + N8N + Open WebUI + SearXNG + Qdrant.

# --- LLM (Ollama local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b-mlx

# --- N8N ---
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/ai-sdr

# --- Open WebUI ---
OPENWEBUI_BASE_URL=http://localhost:3000

# --- Research: SearXNG (busca self-hosted) ---
SEARXNG_BASE_URL=http://localhost:8080

# --- RAG: Qdrant (vector store da base de cases) ---
QDRANT_BASE_URL=http://localhost:6333
QDRANT_COLLECTION=ai_sdr_cases

# --- App ---
APP_ENV=dev
LOG_LEVEL=INFO
